.env
.env.*
!.env.example
.venv/
__pycache__/
*.pyc
_runs/
.DS_Store

# Bloom outputs:
# - keep the shared "understanding" + "ideation" stages so reviewers see the
#   exact scenarios used in the published experiment
# - ignore everything else (per-model results, rollouts, judgments)
bloom-results/conflict-insensitivity-*/
bloom-results/conflict-insensitivity/transcript_*.json
bloom-results/conflict-insensitivity/rollout.json
bloom-results/conflict-insensitivity/judgment*.json
bloom-results/conflict-insensitivity/_index.json
